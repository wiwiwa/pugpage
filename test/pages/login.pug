extends NONE

h1 Login

form(action="/$$dev/api/login" href="/" method="POST")
  div
    label Username
    input(name="username" value="demo")
  div
    label Password
    input(name="password" type="password" value="demo")
  button(type="submit") Login
  if $rest.status === 200
    - $user.setAuthHeader("Bearer " + $rest.data.token, false)
  else
    p.error #{$rest.data.error}
